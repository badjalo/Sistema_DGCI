# ✅ VARIÁVEIS DE AMBIENTE - SF-DGCI Backend
# Copiar para .env e preencher com valores reais em produção

# 🌍 Ambiente
NODE_ENV=development
PORT=5000

# 🗄️ Base de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sf_dgci
DB_USER=postgres
DB_PASSWORD=<DEFINA_UMA_SENHA_FORTE_AQUI>  # ⚠️ OBRIGATÓRIO em produção!

# 🔐 JWT (JSON Web Tokens)
JWT_SECRET=<GERE_UMA_STRING_ALEATORIA_MUITO_LONGA_AQUI>  # ⚠️ Minimo 32 caracteres!
JWT_EXPIRES_IN=24h

# 🌐 URLs (CORS)
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5000

# 📧 Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-app
EMAIL_FROM=noreply@sfdgci.mz

# 📊 Logging
LOG_LEVEL=error
LOG_FILE=logs/combined.log

# 🔒 Redis (opcional, para sessões em produção)
REDIS_URL=redis://localhost:6379

# 📱 Integração
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# 🎨 Públicos (não sensíveis)
APP_NAME=SF-DGCI
APP_VERSION=1.0.0
